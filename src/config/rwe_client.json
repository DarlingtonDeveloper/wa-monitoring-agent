  "false_positive_rules": [
    {
      "pattern": "RWE",
      "exclude_context": ["RWE Shropshire", "wrestling", "RWE Smith"],
      "note": "RWE is a common abbreviation — require energy/power/wind context"
    },
    {
      "pattern": "Sofia",
      "exclude_context": ["Sofia Bulgaria", "Queen Sofia", "Sofia Vergara", "Sofia airport"],
      "note": "Sofia is a common name — require wind/offshore/energy context"
    },
    {
      "pattern": "CfD",
      "exclude_context": ["contract for deed", "computational fluid dynamics"],
      "note": "CfD can mean Contract for Deed or Computational Fluid Dynamics"
    },
    {
      "pattern": "NESO",
      "exclude_context": ["NESCO", "Neso moon"],
      "note": "Filter non-energy NESO references"
    }
  ],

